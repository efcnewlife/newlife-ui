{
  "name": "@efcnewlife/newlife-ui",
  "version": "0.1.0",
  "description": "Shared React UI components for Newlife Portal (Tailwind v4)",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/efcnewlife/newlife-ui.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [],
  "license": "ISC",
  "packageManager": "pnpm@10.27.0",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-icons": "^5.0.0",
    "flatpickr": "^4.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "flatpickr": "^4.6.13",
    "tsup": "^8.4.0",
    "typescript": "~5.7.2"
  }
}